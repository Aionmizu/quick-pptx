# ia-pptx-generator — example environment file.
# Copy to `.env` and fill in real values. The `.env` file is in .gitignore;
# never commit it.
#
# You can also run `python3 -m ia_pptx login` instead — that stores the key
# in ~/.config/ia-pptx/credentials.json (mode 0600), which is loaded
# automatically and works across terminals without copying around .env files.

# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-replace-me

# Optional: override the default model used by the Streamlit surface.
# IA_PPTX_MODEL=claude-sonnet-4-6
